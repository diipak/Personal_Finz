import sys
import pandas as pd
import json
import requests
import re
from engine.rule_engine import categorize

# ==============================
# CONFIG
# ==============================

SELF_NAME = "deepak batham"
LLM_MODEL = "qwen2.5:7b"
OLLAMA_URL = "http://100.103.104.90:11434/api/generate"

ALLOWED_CATEGORIES = [
    "Groceries",
    "Travel",
    "Utilities",
    "Subscription",
    "Transfer",
    "Shopping",
    "Income",
    "Dining",
    "Fuel",
    "Rent",
    "Insurance",
    "Other"
]

LLM_CACHE = {}

# ==============================
# LOAD INPUT FILE
# ==============================

input_file = sys.argv[1]
output_file = sys.argv[2]

df = pd.read_csv(input_file)

# Keep completed transactions only
if "State" in df.columns:
    df = df[df["State"] == "COMPLETED"]

df["Amount"] = df["Amount"].astype(float)

# ==============================
# LOAD MERCHANT RULES
# ==============================

with open("merchant_rules.json", "r") as f:
    rules = json.load(f)

transfer_keywords = rules.get("transfer_keywords", [])
merchant_categories = rules.get("merchant_categories", {})

# ==============================
# HELPER FUNCTIONS
# ==============================

def extract_merchant(description):
    desc = description.lower()
    desc = re.sub(r'[^a-z\s]', ' ', desc)
    words = desc.split()

    # Take first meaningful word
    for word in words:
        if len(word) > 2:
            return word

    return desc.strip()


def ask_llm(description, amount):
    merchant_key = extract_merchant(description)

    if merchant_key in LLM_CACHE:
        return LLM_CACHE[merchant_key]

    prompt = f"""
Classify this financial transaction.

Return ONLY one word from this exact list:
Groceries
Travel
Utilities
Subscription
Transfer
Shopping
Income
Dining
Fuel
Rent
Insurance
Other

Transaction:
Description: {description}
Amount: {amount}

Respond with only the exact category word.
"""

    try:
        response = requests.post(
            OLLAMA_URL,
            json={
                "model": LLM_MODEL,
                "prompt": prompt,
                "stream": False,
                "options": {
                    "temperature": 0,
                    "num_predict": 8,
                    "keep_alive": 0
                }
            },
            timeout=30
        )

        raw = response.json()["response"].strip()
        first_word = raw.split()[0]

        if first_word in ALLOWED_CATEGORIES:
            LLM_CACHE[merchant_key] = first_word
            return first_word
        else:
            LLM_CACHE[merchant_key] = "Other"
            return "Other"

    except:
        return "Other"


def determine_type(description, amount):
    desc = description.lower()

    # Internal self transfer
    if SELF_NAME in desc:
        return "Transfer"

    # Income detection
    if amount > 0:
        return "Income"

    return "Expense"


def determine_category(description, amount):
    desc_lower = description.lower()

    # Self transfer
    if SELF_NAME in desc_lower:
        return "Self Transfer"

    # 2️⃣ Check merchant rule match
    for merchant, category in merchant_categories.items():
        if merchant in desc_lower:
            return category

    # 3️⃣ LLM fallback
    category = ask_llm(description, amount)

    # Save learned rule
    merchant_key = extract_merchant(description)
    merchant_categories[merchant_key] = category

    return category


# ==============================
# APPLY CLASSIFICATION
# ==============================

df["Type"] = df.apply(lambda row: determine_type(row["Description"], row["Amount"]), axis=1)
df["Category"] = df.apply(lambda row: determine_category(row["Description"], row["Amount"]), axis=1)

df["Account"] = "Revolut"

# ==============================
# SAVE UPDATED RULES
# ==============================

rules["merchant_categories"] = merchant_categories

with open("merchant_rules.json", "w") as f:
    json.dump(rules, f, indent=2)

# ==============================
# EXPORT CLEAN FILE
# ==============================

final_df = df[[
    "Completed Date",
    "Description",
    "Amount",
    "Currency",
    "Account",
    "Type",
    "Category"
]]

final_df.to_csv(output_file, index=False)

print("Processing complete.")
print(f"Saved to {output_file}")